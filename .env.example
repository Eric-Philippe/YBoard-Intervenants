# Copy this file to .env and fill in real values. Never commit .env.
# Generate a strong JWT secret with, for example:
#   openssl rand -base64 64

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://user:CHANGE_ME@address:5432/sourcing_intervenants_ynov"

# JWT secret for authentication. Required, no default. Keep it secret.
JWT_SECRET=""

# Feature flag: set to "false" to disable the public survey form and admin dashboard
NEXT_PUBLIC_ENABLE_SONDAGE="true"

# Used only by docker-compose.yml
POSTGRES_PASSWORD=""
